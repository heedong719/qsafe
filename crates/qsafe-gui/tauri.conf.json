{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "qsafe",
  "version": "0.1.6",
  "identifier": "app.qsafe.gui",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "windows": [
      {
        "title": "qsafe — quantum-safe compression",
        "width": 960,
        "height": 640,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "label": "main"
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "fileAssociations": [
      {
        "ext": ["qs"],
        "name": "qsafe Archive",
        "description": "Quantum-safe encrypted archive",
        "role": "Editor",
        "mimeType": "application/x-qsafe"
      },
      {
        "ext": ["iso", "img", "dmg"],
        "name": "Disc Image",
        "description": "Disc / ISO image",
        "role": "Viewer",
        "mimeType": "application/x-iso9660-image"
      }
    ]
  }
}